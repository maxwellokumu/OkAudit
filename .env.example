# IT Audit Team Skills — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ─────────────────────────────────────────────
# AWS Credentials (required for --mode aws)
# ─────────────────────────────────────────────

# AWS access key ID from IAM console
AWS_ACCESS_KEY_ID=

# AWS secret access key from IAM console
AWS_SECRET_ACCESS_KEY=

# Default AWS region (e.g. us-east-1, eu-west-1, af-south-1)
AWS_DEFAULT_REGION=us-east-1

# Optional: use an AWS profile instead of key/secret
# AWS_PROFILE=default

# ─────────────────────────────────────────────
# Azure Credentials (required for --mode azure)
# ─────────────────────────────────────────────

# Azure Active Directory tenant ID
AZURE_TENANT_ID=

# App registration client ID
AZURE_CLIENT_ID=

# App registration client secret
AZURE_CLIENT_SECRET=

# Azure subscription ID (for resource-level queries)
AZURE_SUBSCRIPTION_ID=

# ─────────────────────────────────────────────
# General Settings
# ─────────────────────────────────────────────

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
